    {
      "parameters": {
        "jsCode": "const raw = items[0].json.content.parts[0].text;\n\n// 1. 去掉 markdown code block\nconst cleaned = raw\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\n// 2. 解析 JSON\nlet data;\n\ntry {\n  data = JSON.parse(cleaned);\n} catch (e) {\n  // fallback（防止AI乱输出）\n  return [{\n    json: {\n      name: \"Unknown\",\n      reason: cleaned,\n      query: \"restaurant\"\n    }\n  }];\n}\n\n// 3. 拼 Google Maps URL\nconst lat = $json.lat;\nconst lng = $json.lng;\n\nconst maps_url = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(data.query)}+${lat},${lng}`;\n\nreturn [{\n  json: {\n    name: data.name,\n    reason: data.reason,\n    maps_url\n  }\n}];"
      },
